  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "regions": ["fra1"],
  "functions": {
    "app/api/pdf/route.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "app/api/booking/route.ts": {
      "maxDuration": 10
    }
  }
}
